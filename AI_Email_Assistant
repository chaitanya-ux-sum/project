        "import gradio as gr\n",
        "from transformers import pipeline\n",
        "import torch\n",
        "\n",
        "# 1. SETUP: Following Teacher's Step 8 (Instruction Model)\n",
        "# We use Gemma-2b-it as recommended in the PDF\n",
        "print(\"Loading Model... Please wait.\")\n",
        "generator = pipeline(\n",
        "    \"text-generation\",\n",
        "    model=\"google/gemma-2b-it\",\n",
        "    model_kwargs={\"torch_dtype\": torch.bfloat16},\n",
        "    device_map=\"auto\"\n",
        ")\n",
        "\n",
        "# 2. LOGIC: Following Teacher's Step 14 (Role Prompting)\n",
        "def ai_email_assistant(task_type, tone, details):\n",
        "    # Constructing the Role Prompt as per Practical Example 2\n",
        "    if task_type == \"Generate New Email\":\n",
        "        prompt = f\"Act as a professional AI assistant. Write a {tone} email about the following topic: {details}. Ensure it has a subject, greeting, and closing.\"\n",
        "    else:\n",
        "        prompt = f\"Act as a professional AI assistant. Write a {tone} reply to the following email content: {details}.\"\n",
        "\n",
        "    # Setting max_new_tokens to 300 to ensure 'Total Email' output\n",
        "    output = generator(prompt, max_new_tokens=300, do_sample=True, temperature=0.7)\n",
        "\n",
        "    # Extracting the generated text\n",
        "    return output[0][\"generated_text\"]\n",
        "\n",
        "# 3. INTERFACE: Creating the Gradio Website\n",
        "with gr.Blocks(title=\"MITAOE AI Email Lab\") as demo:\n",
        "    gr.Markdown(\"# 📧 AI Email & Reply Assistant\")\n",
        "    gr.Markdown(\"### Developed following Prompt Engineering Lab Instructions\")\n",
        "\n",
        "    with gr.Row():\n",
        "        with gr.Column():\n",
        "            task = gr.Radio([\"Generate New Email\", \"Reply to Email\"], label=\"Task Selection\", value=\"Generate New Email\")\n",
        "            tone = gr.Dropdown([\"Professional\", \"Formal\", \"Friendly\", \"Urgent\"], label=\"Tone\", value=\"Professional\")\n",
        "            details = gr.Textbox(label=\"Details / Context\", placeholder=\"e.g., Requesting an internship...\", lines=5)\n",
        "            btn = gr.Button(\"Create Email ✨\", variant=\"primary\")\n",
        "\n",
        "        with gr.Column():\n",
        "            result = gr.Textbox(label=\"AI Output\", lines=12)\n",
        "\n",
        "    btn.click(fn=ai_email_assistant, inputs=[task, tone, details], outputs=result)\n",
        "\n",
        "# 4. LAUNCH: Using share=True to get a public link for the teacher\n",
        "demo.launch(share=True)"
      ]
