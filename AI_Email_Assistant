        "    # [span_2](start_span)max_new_tokens=250 ensures the total email is written[span_2](end_span)\n",
        "    result = generator(prompt, max_new_tokens=250, do_sample=True, temperature=0.7)\n",
        "    return result[0][\"generated_text\"]\n",
